---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import SEO from '../components/SEO.astro';
import { getSite } from '../utils/consts';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
}

const site = await getSite();
const { title = site.author.name, description = '', image } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={title} description={description} image={image} />
        {/* THE SEMANTIC BRAIN INJECTION */}
        <SEO />
    </head>
    <body>
        <Header />
        <main class="content-shell">
            <slot />
        </main>
        <Footer />
        
        <BackToTop />
    </body>
</html>

<style is:global>
  /* Force long URLs and text to break instead of stretching the screen */
  p, a, li {
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }
  
  /* Confine code blocks and allow them to scroll horizontally */
  pre {
    max-width: 100vw;
    overflow-x: auto;
    white-space: pre;
  }
  
  /* Ensure the main container doesn't get pushed out of bounds */
  main, article, .content-shell {
    min-width: 0;
    max-width: 100%;
    overflow-x: hidden;
  }

  /* Enforce High-Contrast, Premium Readability for all Articles */
  .post-article p, 
  .post-article li, 
  .post-article .prose {
    color: var(--color-ink) !important;
    font-size: 1.125rem !important;
    line-height: 1.8 !important;
    opacity: 0.95 !important;
  }
  
  .post-article strong {
    color: var(--color-ink) !important;
    font-weight: 800 !important;
  }
</style>