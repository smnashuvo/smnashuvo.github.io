---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import SEO from '../components/SEO.astro';
import { getSite } from '../utils/consts';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	ogType?: 'website' | 'article';
	imageAlt?: string;
	publishDate?: Date;
	updatedDate?: Date;
}

const site = await getSite();
const { 
	title = site.author.name, 
	description = '', 
	image, 
	ogType, 
	imageAlt, 
	publishDate,
	updatedDate 
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={title} description={description} image={image} ogType={ogType} imageAlt={imageAlt} />
        <SEO title={title} description={description} publishDate={publishDate} updatedDate={updatedDate} image={image} isArticle={ogType === 'article'} />
    </head>
    <body>
        <Header />
        <main class="content-shell">
            <slot />
        </main>
        <Footer />
        <BackToTop />
    </body>
</html>

<style is:global>
  /* 1. Universal Text Hardening */
  p, a, li {
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
    /* Clean vertical lines for technical/geopolitical reading */
    text-align: justify;
    hyphens: auto;
  }
  
  /* 2. Confine code blocks */
  pre {
    max-width: 100vw;
    overflow-x: auto;
    white-space: pre;
  }
  
  /* 3. Main container safety */
  main, article, .content-shell {
    min-width: 0;
    max-width: 100%;
    overflow-x: hidden;
  }

  /* 4. Enforce Premium Readability for all Articles & Homepage Bio */
  .post-article p, 
  .post-article li, 
  .post-article .prose,
  .hero-bio {
    color: var(--color-ink) !important;
    font-size: 1.125rem !important;
    line-height: 1.8 !important;
    opacity: 0.95 !important;
    text-align: justify !important;
    hyphens: auto !important;
  }
  
  .post-article strong {
    color: var(--color-ink) !important;
    font-weight: 800 !important;
  }

  /* Prevent awkward gaps in short headings or meta info */
  h1, h2, h3, h4, .post-meta, .eyebrow {
    text-align: left !important;
    hyphens: none !important;
  }
</style>