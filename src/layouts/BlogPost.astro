---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import ConnectedSystems from '../components/ConnectedSystems.astro';
import { slugify, withBase } from '../utils/slugify';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
    heroImage?: ImageMetadata;
    heroAlt?: string;
    closingImage?: ImageMetadata;
    Content?: any;
    tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, heroAlt, closingImage, tags = [], Content } = Astro.props as Props;
---

<BaseLayout title={title} description={description} image={heroImage} ogType="article" imageAlt={heroAlt} publishDate={pubDate} updatedDate={updatedDate}>
    
    <div id="zen-controls" class="fixed bottom-8 right-8 z-50 flex flex-col items-center space-y-4">
        {/* 1. Font Size Button (Clean) */}
        <button id="font-toggle-btn" class="hidden opacity-0 scale-90 transition-all duration-300 p-3 rounded-full bg-[color:var(--color-surface)] border border-[color:var(--color-border)] shadow-xl text-[color:var(--color-ink)] hover:-translate-y-1 cursor-pointer w-12 h-12 flex items-center justify-center font-bold text-xs">
            A<span class="text-[10px]">A</span>
        </button>

        {/* 2. Zen Theme Toggle (Clean - NO RING) */}
        <button id="zen-theme-toggle" class="hidden opacity-0 scale-90 transition-all duration-300 p-3 rounded-full bg-[color:var(--color-surface)] border border-[color:var(--color-border)] shadow-xl text-[color:var(--color-ink)] hover:-translate-y-1 cursor-pointer w-12 h-12 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="zen-sun hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="zen-moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>

        {/* 3. MAIN ZEN TOGGLE: Progress ring is strictly here */}
        <button id="reading-mode-btn" class="relative p-3 rounded-full bg-[color:var(--color-surface)] border border-[color:var(--color-border)] shadow-2xl text-[color:var(--color-ink)] hover:text-ink transition-all hover:-translate-y-1 group cursor-pointer w-14 h-14 flex items-center justify-center overflow-hidden" title="Toggle Zen Reading Mode">
            <svg class="absolute inset-0 w-full h-full -rotate-90 pointer-events-none" viewBox="0 0 56 56">
                <circle cx="28" cy="28" r="26" fill="none" stroke="currentColor" stroke-width="2" class="text-[color:var(--color-border)]" opacity="0.3"></circle>
                <circle id="reading-progress-ring" cx="28" cy="28" r="26" fill="none" stroke="currentColor" stroke-width="2" class="text-[color:var(--color-ink)] transition-[stroke-dashoffset] duration-150 ease-out" stroke-dasharray="163.36" stroke-dashoffset="163.36"></circle>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-[.active]:hidden relative z-10"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden group-[.active]:block relative z-10"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
        </button>
    </div>

    <div class="flex-1 flex flex-col py-12 md:py-16 lg:py-20 space-y-16">
        <article class="post-page max-w-4xl w-full mx-auto">
            <header class="section-heading transition-all duration-500">
                <p class="eyebrow text-sm uppercase tracking-[0.35em] text-muted mb-4 transition-all duration-500">Journal</p>
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-ink leading-tight tracking-tight mb-6 [text-wrap:balance]">{title}</h1>
                <p class="post-meta text-muted transition-all duration-500">
                    <FormattedDate date={pubDate} />
                    {updatedDate && (<span>&middot; Updated <FormattedDate date={updatedDate} /></span>)}
                </p>
                {tags.length > 0 && (
                    <ul class="mt-6 flex flex-wrap gap-2 text-sm text-muted transition-all duration-500">
                        {tags.map((tag) => (
                            <li class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 transition-all duration-500">
                                <a class="hover:text-ink transition-colors" href={withBase(`/tags/${slugify(tag)}/`)}>{tag}</a>
                            </li>
                        ))}
                    </ul>
                )}
            </header>

{heroImage && (
                <figure class="post-hero-image mt-8 mb-12 flex justify-center transition-all duration-500">
                    <a href={typeof heroImage === 'string' ? heroImage : heroImage.src} 
                       target="_blank" 
                       rel="noopener noreferrer" 
                       class="inline-block rounded-[2rem] overflow-hidden border border-[color:var(--color-border)] shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-zoom-in">
                        <Image 
                            src={heroImage} 
                            alt={heroAlt ?? ''} 
                            width={heroImage.width}
                            height={heroImage.height}
                            class="block w-auto max-w-full mx-auto" 
                            style="max-height: 520px; object-fit: contain;" 
                            loading="eager" 
                            fetchpriority="high" 
                        />
                    </a>
                </figure>
            )}
            <section class="post-article mt-10">
                <Prose>{Content ? <Content /> : <slot />}</Prose>
            </section>

            {closingImage && (
                <figure class="post-closing-image mt-8 mb-12 flex justify-center transition-all duration-500">
                    <a href={typeof closingImage === 'string' ? closingImage : closingImage.src}
                       target="_blank"
                       rel="noopener noreferrer"
                       class="inline-block rounded-[2rem] overflow-hidden border border-[color:var(--color-border)] shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-zoom-in">
                        <Image
                            src={closingImage}
                            alt={heroAlt ?? title}
                            class="block w-auto max-w-full mx-auto"
                            style="max-height: 480px; object-fit: contain;"
                            loading="lazy"
                            fetchpriority="low"
                        />
                    </a>
                </figure>
            )}

            <ConnectedSystems currentTitle={title} tags={tags} collectionType="writings" />

            <div class="distribution-lever mt-8 pt-8 border-t border-[color:var(--color-border)] flex justify-center transition-all duration-500">
                <button id="share-doc-btn" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:bg-[color:var(--color-surface)] text-xs font-bold uppercase tracking-[0.2em] text-muted hover:text-ink transition-all duration-300 cursor-pointer">
                    <span id="share-doc-text">Share</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
                </button>
            </div>
        </article>
    </div>
</BaseLayout>

<script>
    const btn = document.getElementById('reading-mode-btn');
    const fontBtn = document.getElementById('font-toggle-btn');
    const themeBtn = document.getElementById('zen-theme-toggle');
    const body = document.body;
    
    btn?.addEventListener('click', () => {
        const isActive = body.classList.toggle('reading-mode-active');
        btn.classList.toggle('active');
        if (isActive) {
            const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
            body.setAttribute('data-zen-theme', currentTheme);
            [fontBtn, themeBtn].forEach(el => {
                el?.classList.remove('hidden');
                setTimeout(() => el?.classList.add('opacity-100', 'scale-100', 'translate-y-0', 'flex'), 10);
            });
        } else {
            [fontBtn, themeBtn].forEach(el => {
                el?.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
                setTimeout(() => el?.classList.add('hidden'), 300);
            });
            body.removeAttribute('data-zen-font');
            body.removeAttribute('data-zen-theme');
        }
    });

    const fonts = ['medium', 'large', 'small'];
    let currentFont = 0;
    fontBtn?.addEventListener('click', () => {
        currentFont = (currentFont + 1) % fonts.length;
        body.setAttribute('data-zen-font', fonts[currentFont]);
    });

    themeBtn?.addEventListener('click', () => {
        const currentZen = body.getAttribute('data-zen-theme');
        const nextZen = currentZen === 'dark' ? 'light' : 'dark';
        body.setAttribute('data-zen-theme', nextZen);
        themeBtn.querySelector('.zen-sun')?.classList.toggle('hidden', nextZen !== 'light');
        themeBtn.querySelector('.zen-moon')?.classList.toggle('hidden', nextZen !== 'dark');
    });

    const progressRing = document.getElementById('reading-progress-ring');
    const circumference = 163.36;
    if (progressRing) {
        window.addEventListener('scroll', () => {
            const scrollY = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            if (docHeight <= 0) return; 
            const scrollFraction = Math.max(0, Math.min(1, scrollY / docHeight));
            const drawAmount = circumference - (scrollFraction * circumference);
            progressRing.style.strokeDashoffset = String(drawAmount);
        }, { passive: true });
    }

    const shareBtn = document.getElementById('share-doc-btn');
    const shareText = document.getElementById('share-doc-text');
    shareBtn?.addEventListener('click', async () => {
        const url = window.location.href;
        const title = document.title;
        if (navigator.share) {
            try { await navigator.share({ title, url }); } 
            catch (err: any) { if (err.name !== 'AbortError') copyToClipboard(url); }
        } else { copyToClipboard(url); }
    });

    function copyToClipboard(url: string) {
        navigator.clipboard.writeText(url).then(() => {
            if (shareText) {
                const originalText = shareText.innerText;
                shareText.innerText = "Link Copied";
                shareText.classList.add("text-ink");
                setTimeout(() => {
                    shareText.innerText = originalText;
                    shareText.classList.remove("text-ink");
                }, 2000);
            }
        });
    }
</script>

<style is:global>
    body { transition: background-color 0.8s ease, color 0.8s ease !important; }

    /* Fix for manual images inside the Markdown body */
    .post-article img {
        display: block !important;
        margin: 3rem auto !important; /* Spacing: mt-12 mb-8 */
        max-height: 480px !important;
        width: auto !important;
        max-width: 100% !important;
        object-fit: contain !important;
        border-radius: 2rem !important;
        border: 1px solid var(--color-border) !important;
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1) !important;
        transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    }

    .post-article img:hover {
        transform: translateY(-4px) !important;
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1) !important;
    }
    /* HARDENED ZEN THEME (Your Explicit Hex Codes) */
    body.reading-mode-active[data-zen-theme="light"] {
        --color-paper: #ededed !important;
        --color-surface: #e0e0e0 !important;
        --color-ink: #111111 !important;
        --color-muted: color-mix(in oklab, var(--color-ink) 72%, transparent) !important;
        --color-border: color-mix(in oklab, var(--color-ink) 18%, transparent) !important;
    }

    body.reading-mode-active[data-zen-theme="dark"] {
        --color-paper: #1a1a1a !important;
        --color-surface: #262626 !important;
        --color-ink: #ffffff !important;
        --color-muted: color-mix(in oklab, var(--color-ink) 70%, transparent) !important;
        --color-border: color-mix(in oklab, var(--color-ink) 20%, transparent) !important;
    }

    /* INVISIBLE TEXT PREVENTION: Hard-coding contrast for Markdown features */
    body.reading-mode-active .post-article code,
    body.reading-mode-active .post-article strong,
    body.reading-mode-active .post-article pre,
    body.reading-mode-active .post-article a {
        color: var(--color-ink) !important;
    }

    .post-article p, .post-article li { transition: font-size 0.4s ease, line-height 0.4s ease, color 0.4s ease !important; }
    body[data-zen-font="small"] .post-article p, body[data-zen-font="small"] .post-article li { font-size: 1.125rem !important; line-height: 1.8 !important; }
    body.reading-mode-active .post-article p, 
    body.reading-mode-active .post-article li { 
        font-size: 1.25rem !important; 
        line-height: 2 !important;
        text-align: left !important;
        hyphens: none !important;
    }
    body[data-zen-font="large"] .post-article p, body[data-zen-font="large"] .post-article li { font-size: 1.5rem !important; line-height: 2.2 !important; }

    body.reading-mode-active header:first-of-type, body.reading-mode-active footer { opacity: 0; pointer-events: none; display: none !important; }
    body.reading-mode-active .section-heading .eyebrow, body.reading-mode-active .post-meta, body.reading-mode-active .section-heading ul { opacity: 0; pointer-events: none; height: 0; margin: 0; overflow: hidden; transition: all 0.5s ease; }
    body.reading-mode-active .post-page { max-width: 720px !important; transition: max-width 0.5s ease !important;}
    body.reading-mode-active .post-hero-image, body.reading-mode-active .post-article img { opacity: 0.15; filter: grayscale(100%); transition: all 0.5s ease !important; }
    body.reading-mode-active .connected-systems, body.reading-mode-active .distribution-lever { opacity: 0; pointer-events: none; height: 0; margin: 0; overflow: hidden; transition: all 0.5s ease; }
</style>
