---
import { getSite } from "../utils/consts";
import type { ImageMetadata } from 'astro';

interface Props {
    title?: string;
    description?: string;
    publishDate?: Date;
    updatedDate?: Date;
    image?: ImageMetadata;
    isArticle?: boolean;
}

const { title, description, publishDate, updatedDate, image, isArticle = false } = Astro.props;
const site = await getSite();
const personName = "S M Nazmul Alam";
const handle = "smnashuvo";
const email = "hello@smnazmul.com";
const siteUrl = "https://smnazmul.com";

const personSchema = {
  "@type": "Person",
  "name": personName,
  "alternateName": [handle, 'এস এম নাজমুল আলম'],  
  "url": siteUrl,
  "mainEntityOfPage": siteUrl,
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}/me.jpg`,
      "width": 880,
      "height": 1168
  },
  "jobTitle": [
    "Freelance Interpreter",
    "Systems & Digital Strategy Consultant",
    "Independent Writer and Analyst",
    "Human Rights Activist"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Independent"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Chattogram",
    "addressRegion": "Chattogram",
    "addressCountry": "BD"
  },
  "description": "Bridging technology and strategy through a systems-first lens. Working with AI workflows and digital tools, driven by independent exploration of how complex systems operate, connect, and evolve across domains.",
  "knowsAbout": [
    "Systems & Digital Strategy",
    "Technology and Cybernetics",
    "Global Politics & Geopolitics",
    "Policy Analysis & Governance",
    "Civilization Studies",
    "Anthropology & Archaeology",
    "Corporate and Business Analysis",
    "Education Systems & Development",
    "Linguistic Interpretation",
    "Environment & Sustainability"
  ],
  "sameAs": [
    `https://github.com/${handle}`,
    `https://www.linkedin.com/in/${handle}/`,
    `https://x.com/${handle}`,
    `https://facebook.com/${handle}`,
    "https://independent.academia.edu/SMNazmulAlam",
    `https://about.me/${handle}`,
    `https://www.youtube.com/@${handle}`,
    `https://www.rumble.com/user/${handle}`,
    `https://scholar.google.com/citations?user=FuCrfwsAAAAJ&hl=en`,
    "https://medium.com/@smnashuvo",
    "https://www.instagram.com/smnashuvo",
    "https://www.twitch.tv/smnashuvo",
    "https://www.patreon.com/smnashuvo",
    "https://www.substack.com/@smnashuvo",
    "https://orcid.org/0009-0000-6593-2827"
  ]
};

let schemas: any[] = [personSchema];

if (isArticle && title) {
  schemas.push({
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": image ? new URL(image.src, siteUrl).toString() : undefined,
    "datePublished": publishDate?.toISOString(),
    "dateModified": updatedDate ? updatedDate.toISOString() : publishDate?.toISOString(),
    "author": {
      "@type": "Person",
      "name": personName,
      "url": siteUrl
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": Astro.url.toString()
    }
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": schemas
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />