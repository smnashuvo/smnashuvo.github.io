---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-about.png';
import { getSite } from '../utils/consts';
import { SEO } from 'astro-seo';

const site = await getSite();

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const { title, description, image = FallbackImage } = Astro.props;

/** * THE FIX: Fallback logic. 
 * If 'description' prop is empty, use 'author.bio' from site-config.yml.
 */
const finalDescription = description || site.author.bio || "Systems & Strategy Consultant | AI & Digital Strategy";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL((image as ImageMetadata).src, Astro.site ?? Astro.url);
---

<script is:inline>
  // THE OVERRIDE: Forces Dark Mode on initial load regardless of OS settings
  const theme = (() => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return 'dark'; // FORCED DEFAULT
  })();
  document.documentElement.dataset.theme = theme;
  
  if (theme === 'light') {
    document.documentElement.classList.remove('dark');
  } else {
    document.documentElement.classList.add('dark');
  }
</script>

<SEO
	charset="utf-8"
	title={title}
	description={finalDescription}
	canonical={canonicalURL.toString()}
	openGraph={{
		basic: {
			title,
			type: 'website',
			image: imageURL.toString(),
			url: canonicalURL.toString(),
		},
		optional: {
			description: finalDescription,
			siteName: site.author.name || 'S M Nazmul Alam',
		},
	}}
	twitter={{
		card: 'summary_large_image',
		title,
		description: finalDescription,
		image: imageURL.toString(),
		imageAlt: title,
	}}
	extend={{
		link: [
			{ rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
			{ rel: 'sitemap', href: '/sitemap-index.xml' },
			{ rel: 'alternate', type: 'application/rss+xml', title: site.title, href: new URL('rss.xml', Astro.site).toString() },
		],
		meta: [
			{ name: 'viewport', content: 'width=device-width,initial-scale=1' },
			{ name: 'generator', content: Astro.generator },
			{ name: 'description', content: finalDescription }, // Explicitly forcing the tag for Lighthouse
		],
	}}
/>