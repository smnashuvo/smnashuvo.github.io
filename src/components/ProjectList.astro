---
import { Image } from "astro:assets";
import { getCollection } from 'astro:content';
import { withBase, slugify } from '../utils/slugify';

interface RawProject {
    id?: string;
    data?: {
        title?: string;
        description?: string;
        heroImage?: any;
        pubDate?: Date | string;
        domain?: string | string[];
        tags?: string[];
    };
    title?: string;
    description?: string;
    heroImage?: any;
    pubDate?: Date | string;
}

export interface Props {
    heading?: string;
    items?: RawProject[];
    limit?: number;
    viewAllHref?: string;
    viewAllLabel?: string;
}

let {
    heading = "Lab",
    items = [],
    limit = 4,
    viewAllHref = "/lab",
    viewAllLabel = "View all in Lab",
} = Astro.props as Props;

function getProjectData(item: RawProject) {
    return item && (item as any).data ? (item as any).data : item;
}

if (items.length === 0) {
    items = items.concat(await getCollection("lab")).sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
    );
}

const visibleItems = typeof limit === "number" ? items.slice(0, limit) : items;
---

<section class="content-shell">
    <div>
        <div class="grid grid-cols-1 gap-y-12 md:grid-cols-3 border-b py-24 border-[color:var(--color-border)]">
            <div class="lg:sticky lg:top-24 lg:z-40 self-start">
                <h2 class="text-sm 2xl:text-xl text-ink font-bold uppercase tracking-[0.2em]">
                    {heading}
                </h2>
            </div>

            <div class="lg:col-span-2 flex flex-col space-y-6">
                {
                    visibleItems.map((item) => {
                        const p = getProjectData(item) || {};
                        const rawId = (item as any).id;

                        /** IDENTITY ANCHOR LOGIC: Prepend Domain & Strip Extension */
                        const cleanId = rawId ? rawId.replace(/\.[^/.]+$/, "") : "";
                        const rawDomain = Array.isArray(p.domain) ? p.domain[0] : p.domain;
                        
                        const linkSlug = cleanId.includes('/') 
                            ? cleanId 
                            : (rawDomain ? `${slugify(rawDomain)}/${cleanId}` : cleanId);

                        const href = rawId ? withBase(`/lab/${linkSlug}/`) : p.href;
                        const domainStr = rawDomain || null;

                        return (
                            <a
                                class="group block w-full overflow-hidden rounded-[28px] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6 shadow-none transition duration-200 hover:-translate-y-[2px] hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)]"
                                href={href}
                            >
                                <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">
                                    {p.heroImage && (
                                        <div class="shrink-0 w-full md:w-48 aspect-[16/9] md:aspect-[4/3] rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
                                            <Image src={p.heroImage} alt={p.title || ""} class="w-full h-full object-cover transition duration-500 group-hover:scale-105" width={400} height={300} />
                                        </div>
                                    )}
                                    
                                    <div class="flex flex-col flex-1 w-full">
                                        {domainStr && (
                                            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-muted mb-2">
                                                {domainStr}
                                            </p>
                                        )}

                                        <h3 class="text-2xl font-bold text-ink group-hover:text-ink">{p.title}</h3>
                                        <p class="mt-3 text-base text-muted line-clamp-2 leading-relaxed">{p.description}</p>

                                        <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-[color:var(--color-border)] pt-4">
                                            <span class="text-xs font-bold uppercase tracking-[0.1em] text-ink group-hover:text-base-500 transition-colors">
                                                View Warlog →
                                            </span>
                                            
                                            {p.pubDate && (
                                                <time class="text-xs uppercase tracking-[0.4em] text-muted" datetime={new Date(p.pubDate).toISOString()}>
                                                    {new Date(p.pubDate).toLocaleDateString('en-US', {
                                                        day: 'numeric',
                                                        month: 'short',
                                                        year: 'numeric',
                                                    })}
                                                </time>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </a>
                        );
                    })
                }
                
                <a href={withBase(viewAllHref)} class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-[0.1em] text-ink hover:text-base-500 transition-colors pt-4">
                    {viewAllLabel} 
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>