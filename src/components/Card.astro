---
import { Image } from 'astro:assets';

interface Props {
    title: string;
    description?: string;
    date?: Date | string;
    image?: any;
    imageAlt?: string;
    href: string;
    variant?: string;
    cta?: string;
}

const { title, description, date, image, imageAlt, href, cta } = Astro.props;
const baseDate = typeof date === 'string' ? new Date(date) : date;
---

<a
    class="group block w-full overflow-hidden rounded-[28px] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5 md:p-6 shadow-none transition duration-200 hover:-translate-y-[2px] hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)]"
    href={href}
>
    <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">
        {image && (
            <div class="shrink-0 w-full md:w-56 aspect-[16/9] md:aspect-[4/3] rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-ink)_5%,transparent)]">
                {typeof image === 'string' ? (
                    <img src={image} alt={imageAlt || title} class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
                ) : (
                    <Image src={image} alt={imageAlt || title} width={400} height={300} class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
                )}
            </div>
        )}

        <div class="flex flex-col flex-1 w-full min-w-0">
            <h3 class="text-2xl font-bold text-ink group-hover:text-ink">{title}</h3>
            
            {description && (
                <p class="mt-3 text-base text-muted line-clamp-2 leading-relaxed">{description}</p>
            )}

            <div class="mt-6 flex flex-col gap-4 border-t border-[color:var(--color-border)] pt-4">
                <div class="relative z-10 text-[0.95rem]">
                    <slot />
                </div>
                
                <div class="flex flex-wrap items-center justify-between gap-4 w-full">
                    {baseDate && (
                        <time class="text-xs uppercase tracking-[0.4em] text-muted" datetime={baseDate.toISOString()}>
                            {baseDate.toLocaleDateString('en-US', {
                                day: 'numeric',
                                month: 'short',
                                year: 'numeric',
                            })}
                        </time>
                    )}
                    {cta && (
                        <span class="text-xs font-bold uppercase tracking-[0.1em] text-ink hover:text-base-500 transition-colors">
                            {cta}
                        </span>
                    )}
                </div>
            </div>
        </div>
    </div>
</a>