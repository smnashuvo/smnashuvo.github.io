---
import { getSite } from "../utils/consts";
import HeaderLink from "./HeaderLink.astro";
import SearchModal from "./SearchModal.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { Icon } from 'astro-icon/components';

const site = await getSite();
---

<header class="site-header w-full relative z-[50]">
  <nav class="h-full w-full flex items-center justify-between md:justify-end">
    
    {/* MENU BUTTON: Preserved hit-box refinement, no white box */}
    <button
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-pressed="false"
      class="md:hidden text-xs 2xl:text-lg text-base-900 hover:text-base-500 font-bold uppercase border-none bg-transparent p-4 -m-4 outline-none shadow-none z-[1001]"
    >
      Menu
    </button>

    <div class="hidden md:flex items-center gap-6">
      <div class="flex items-center gap-6 text-xs 2xl:text-lg text-base-900 font-bold uppercase">
        <HeaderLink href="/">Home</HeaderLink>
        
        {/* DESKTOP WRITINGS PILLARS */}
        <div class="relative group">
          <a href="/writings" class="flex items-center gap-1 hover:text-base-500 py-2">
            Writings
            <Icon name="tabler:chevron-down" class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" />
          </a>
          <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
            <div class="flex flex-col w-64 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] shadow-xl overflow-hidden">
              <a href="/writings/statecraft" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Power & Statecraft</a>
              <a href="/writings/civilization" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Civilization</a>
              <a href="/writings/infrastructure" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Systems & Infrastructure</a>
              <a href="/writings/cyber" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Technology & Cyber</a>
            </div>
          </div>
        </div>

        {/* DESKTOP LAB DOMAINS */}
        <div class="relative group">
          <a href="/lab" class="flex items-center gap-1 hover:text-base-500 py-2">
            Lab
            <Icon name="tabler:chevron-down" class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" />
          </a>
          <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
            <div class="flex flex-col w-56 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] shadow-xl overflow-hidden">
              <a href="/lab/ai" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">AI</a>
              <a href="/lab/android" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Android</a>
              <a href="/lab/systems" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Systems</a>
              <a href="/lab/reverse-engineering" class="px-4 py-3 hover:bg-[color-mix(in_oklab,var(--color-ink)_8%,transparent)] transition-colors">Reverse Engineering</a>
            </div>
          </div>
        </div>

        <HeaderLink href="/about">About</HeaderLink>
      </div>

      <div class="flex items-center gap-4 border-l border-gray-300 dark:border-gray-700 pl-4 text-base-900">
        <a href="/connect" class="text-xs 2xl:text-lg font-bold uppercase hover:text-base-500 transition-colors">Connect</a>
        <SearchModal />
        <ThemeToggle />
      </div>
    </div>

    {/* MOBILE NAVIGATION TRAY */}
    <div 
      id="mobile-nav" 
      role="dialog" 
      aria-label="Mobile navigation" 
      aria-hidden="true" 
      style="display:none;"
      class="fixed inset-0 z-[1000] p-8 overflow-auto bg-[var(--color-paper)] text-[var(--color-ink)]"
    >
      <button 
        id="mobile-close" 
        aria-label="Close navigation" 
        class="absolute right-4 top-4 p-2 text-ink hover:text-base-500 border-none bg-transparent outline-none shadow-none"
      >
        <Icon name="tabler:x" class="w-8 h-8" />
      </button>
      
      <div id="mobile-content" class="flex flex-col gap-6 items-start mt-8 w-full">
        <div class="flex flex-col gap-4 text-xl font-bold uppercase w-full">
          <HeaderLink href="/" class="w-fit">Home</HeaderLink>
          <div class="flex flex-col gap-2">
            <HeaderLink href="/writings" class="w-fit">Writings</HeaderLink>
            <div class="flex flex-col gap-3 pl-4 border-l-2 border-[color:var(--color-border)] text-sm text-base-900">
              <a href="/writings/statecraft" class="w-fit hover:text-base-500">Power & Statecraft</a>
              <a href="/writings/civilization" class="w-fit hover:text-base-500">Civilization</a>
              <a href="/writings/infrastructure" class="w-fit hover:text-base-500">Systems & Infrastructure</a>
              <a href="/writings/cyber" class="w-fit hover:text-base-500">Technology & Cyber</a>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <HeaderLink href="/lab" class="w-fit">Lab</HeaderLink>
            <div class="flex flex-col gap-3 pl-4 border-l-2 border-[color:var(--color-border)] text-sm text-base-900">
              <a href="/lab/ai" class="w-fit hover:text-base-500">AI</a>
              <a href="/lab/android" class="w-fit hover:text-base-500">Android</a>
              <a href="/lab/systems" class="w-fit hover:text-base-500">Systems</a>
              <a href="/lab/reverse-engineering" class="w-fit hover:text-base-500">Reverse Engineering</a>
            </div>
          </div>
          <HeaderLink href="/about" class="w-fit">About</HeaderLink>
          <HeaderLink href="/connect" class="w-fit">Connect</HeaderLink>
        </div>

        <hr class="w-full border-[color:var(--color-border)]" />

        <div class="flex items-center gap-6 text-base-900">
          <button 
            aria-label="Open Search" 
            id="mobile-search-btn" 
            class="hover:text-base-500 transition-colors cursor-pointer flex items-center justify-center border-none bg-transparent"
          >
            <Icon name="tabler:search" class="w-6 h-6" />
          </button>
          <ThemeToggle class="hover:text-base-500" />
        </div>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  const navButton = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const mobileClose = document.getElementById("mobile-close");
  const mobileSearch = document.getElementById("mobile-search-btn");

  const applyNav = (state) => {
    const isOpen = state === "open";
    document.documentElement.dataset.nav = isOpen ? "open" : "closed";
    if (navButton) navButton.setAttribute("aria-pressed", isOpen ? "true" : "false");
    if (mobileNav) {
      mobileNav.style.display = isOpen ? "block" : "none";
      mobileNav.setAttribute("aria-hidden", isOpen ? "false" : "true");
    }
  };

  const toggleNav = () => applyNav(document.documentElement.dataset.nav === "open" ? "closed" : "open");
  const closeNav = () => applyNav("closed");

  if (navButton) navButton.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleNav();
  });

  if (mobileClose) mobileClose.addEventListener("click", closeNav);

  // FIXED: mobile search trigger - bypasses potential state race conditions
  if (mobileSearch) {
    mobileSearch.addEventListener("click", (e) => {
      e.preventDefault();
      const searchToggle = document.getElementById('search-toggle');
      if (searchToggle) {
        closeNav();
        // Delay trigger to ensure mobile-nav cleanup doesn't block search opening
        window.requestAnimationFrame(() => searchToggle.click());
      }
    });
  }

  // FIXED: Blank Spots logic - restricted to the mobile navigation lifecycle
  if (mobileNav) {
    mobileNav.addEventListener("click", (e) => {
      if (document.documentElement.dataset.nav !== "open") return;
      const isInteractive = e.target.closest('a') || e.target.closest('button') || e.target.closest('.theme-toggle');
      if (!isInteractive) closeNav();
    });
  }

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.documentElement.dataset.nav === 'open') closeNav();
  });
</script>