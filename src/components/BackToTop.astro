<button 
    id="back-to-top-btn" 
    class="fixed bottom-24 right-[38px] z-50 p-3 rounded-full bg-[color:var(--color-surface)] border border-[color:var(--color-border)] shadow-2xl text-muted hover:text-ink transition-all duration-500 opacity-0 pointer-events-none translate-y-4 group cursor-pointer" 
    title="Back to Top"
    aria-label="Back to Top"
>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:-translate-y-1">
        <path d="m18 15-6-6-6 6"/>
    </svg>
</button>

<script>
    const bttBtn = document.getElementById('back-to-top-btn');

    if (bttBtn) {
        window.addEventListener('scroll', () => {
            // The button remains dead and invisible until the user is 600px deep
            if (window.scrollY > 600) {
                bttBtn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
                bttBtn.classList.add('opacity-100', 'translate-y-0');
            } else {
                bttBtn.classList.remove('opacity-100', 'translate-y-0');
                bttBtn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
            }
        });

        bttBtn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    }
</script>

<style is:global>
    /* If Zen Reading Mode is active, hide the Back to Top button to keep the screen purely text */
    body.reading-mode-active #back-to-top-btn {
        opacity: 0 !important;
        pointer-events: none !important;
    }
</style>