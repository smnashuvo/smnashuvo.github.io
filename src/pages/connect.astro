---
import PageLayout from '../layouts/PageLayout.astro';
import { getSite } from '../utils/consts';
import { Icon } from 'astro-icon/components';
import ChatToggle from '../components/ChatToggle.astro';

const site = await getSite();
const author = site.author || {};
const allSocials = site.social || [];
---

<PageLayout 
    title={`Connect · ${author.name || 'S M Nazmul Alam'}`}
    description={author.description}
>
    <section class="content-shell py-12 space-y-12">
        <header class="space-y-3">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-muted">Network</p> 
            <h1 class="text-4xl md:text-5xl font-black text-ink tracking-tight">Connect</h1>
            <p class="text-ink opacity-80 text-lg max-w-3xl leading-relaxed">
                {author.description}
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 pt-10 border-t border-[var(--color-border)]">
            
            {/* 1. SECURE COMMS */}
            <div class="space-y-6">
                <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-ink">Secure Comms</h2>
                <p class="text-muted text-base leading-relaxed">
                    For professional English↔Bengali interpretation services, independent consulting inquiries on digital strategies & AI implementation.
                </p>
                <a 
                    href={`mailto:${author.email}`}
                    class="inline-block text-xl font-black text-ink hover:text-base-500 transition-colors underline decoration-2 underline-offset-8 decoration-[var(--color-border)] hover:decoration-base-500"
                >
                    {author.email} ↗
                </a>
            </div>

            {/* 2. DIGITAL IDENTITY */}
            <div class="space-y-6">
                <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-ink">Digital Identity</h2>
                <div class="flex flex-wrap gap-8">
                    {allSocials.filter((s) => s.featured).map((s) => (
                        <a 
                            href={s.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-muted hover:text-ink transition-all duration-300 hover:-translate-y-1"
                            title={s.label}
                            aria-label={s.label}
                        >
                            {s.icon ? (
                                <Icon name={s.icon} class="w-6 h-6" />
                            ) : (
                                <span class="text-base font-medium">{s.label}</span>
                            )}
                        </a>
                    ))}
                </div>
            </div>
        </div>

        <div class="pt-12 pb-8 text-center md:text-left">
            <p class="text-sm font-bold uppercase tracking-[0.4em] text-muted opacity-40">Hustle with Loyalty & Respect.</p>
        </div>
    </section>

    <ChatToggle />
</PageLayout>