---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { getSite } from '../../utils/consts';
import { withBase, slugify } from '../../utils/slugify';

export async function getStaticPaths() {
    const allDomains = ['ai', 'android', 'systems', 'reverse-engineering'];
    const allProjects = (await getCollection('lab').catch(() => [])) || []; 
    
    return allDomains.map((domain) => ({
        params: { domain },
        props: { 
            projects: allProjects.filter((p) => {
                const rawData = p?.data?.domain;
                if (!rawData) return false;
                const postDomains = Array.isArray(rawData) ? rawData : [rawData];
                return postDomains.some(val => slugify(val) === domain);
            }).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
            domainName: domain
        },
    }));
}

const { projects = [], domainName = 'android' } = Astro.props;
const site = await getSite();

const titleMap = {
    'ai': 'AI',
    'android': 'Android',
    'systems': 'Systems Engineering',
    'reverse-engineering': 'Reverse Engineering'
};

const displayTitle = titleMap[domainName as keyof typeof titleMap] || domainName;
---

<PageLayout title={`${displayTitle} · Lab`} description={`Technical logs and war stories for ${displayTitle}.`}>
    <section class="content-shell py-12 space-y-10">
        <header class="space-y-2">
            <p class="text-sm uppercase tracking-[0.35em] text-muted">Lab Domain</p>
            <h1 class="text-4xl font-semibold text-ink">{displayTitle}</h1>
        </header>
        
        {projects.length === 0 ? (
            <p class="text-muted">No warlogs published in this domain yet.</p>
        ) : (
            <div class="space-y-6">
                {projects.map((project) => {
                    const rawDomain = Array.isArray(project.data.domain) ? project.data.domain[0] : project.data.domain;
                    
                    /** * IDENTITY ANCHOR LINK LOGIC */
                    const cleanId = project.id.replace(/\.[^/.]+$/, "");
                    const linkSlug = cleanId.includes('/') 
                        ? cleanId 
                        : (rawDomain ? `${slugify(rawDomain)}/${cleanId}` : cleanId);

                    return (
                        <a
                            class="group block w-full overflow-hidden rounded-[28px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition duration-200 hover:-translate-y-[2px] hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)]"
                            href={withBase(`/lab/${linkSlug}/`)}
                        >
                            <div class="flex flex-col">
                                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-muted mb-2">
                                    {titleMap[slugify(rawDomain) as keyof typeof titleMap] || rawDomain}
                                </p>

                                <h3 class="text-2xl font-bold text-ink group-hover:text-ink">{project.data.title}</h3>
                                <p class="mt-3 text-base text-muted line-clamp-2 leading-relaxed">{project.data.description}</p>

                                <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-[var(--color-border)] pt-4">
                                    {project.data.tags && project.data.tags.length > 0 && (
                                        <div class="flex flex-wrap gap-2">
                                            {project.data.tags.slice(0, 3).map((tag: string) => (
                                                <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 text-xs text-muted">
                                                    {tag}
                                                </span>
                                            ))}
                                            {project.data.tags.length > 3 && (
                                                <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 text-xs text-muted">
                                                    +{project.data.tags.length - 3}
                                                </span>
                                            )}
                                        </div>
                                    )}

                                    <time class="text-xs uppercase tracking-[0.4em] text-muted" datetime={project.data.pubDate.toISOString()}>
                                        {project.data.pubDate.toLocaleDateString('en-US', {
                                            day: 'numeric',
                                            month: 'short',
                                            year: 'numeric',
                                        })}
                                    </time>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        )}
    </section>
</PageLayout>