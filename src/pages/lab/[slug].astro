---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectPost from '../../layouts/ProjectPost.astro';

export async function getStaticPaths() {
	// Point to the new lab collection
	const projects = await getCollection('lab');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

// Define the Props based on the lab schema
type Props = CollectionEntry<'lab'>;

const project = Astro.props as Props;
const { Content } = await render(project);
---
<ProjectPost {...project.data}>
	<Content />
</ProjectPost>