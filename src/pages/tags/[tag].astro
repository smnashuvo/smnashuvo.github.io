---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { getSite } from '../../utils/consts';
import { slugify, withBase } from '../../utils/slugify';

export async function getStaticPaths() {
    const writings = await getCollection('writings');
    const lab = await getCollection('lab');
    const allEntries = [...writings, ...lab];
    
    const tags = new Map<string, string>();
    allEntries.forEach((entry) => {
        (entry.data.tags ?? []).forEach((tag) => {
            tags.set(slugify(tag), tag);
        });
    });

    return Array.from(tags.entries()).map(([slug, label]) => ({
        params: { tag: slug },
        props: { tagLabel: label },
    }));
}

const site = await getSite();
const { tagLabel } = Astro.props;
const tagParam = Astro.params.tag;

// Fetch and unify both collections with their specific routing logic
const writingPosts = (await getCollection('writings')).filter((post) =>
    (post.data.tags ?? []).some((tag) => slugify(tag) === tagParam)
).map(p => {
    const rawPillar = Array.isArray(p.data.pillar) ? p.data.pillar[0] : p.data.pillar;
    const cleanId = p.id.replace(/\.[^/.]+$/, "");
    const linkSlug = cleanId.includes('/') ? cleanId : (rawPillar ? `${rawPillar}/${cleanId}` : cleanId);
    return { ...p, href: withBase(`/writings/${linkSlug}/`), type: 'Journal' };
});

const labPosts = (await getCollection('lab')).filter((post) =>
    (post.data.tags ?? []).some((tag) => slugify(tag) === tagParam)
).map(p => {
    const rawDomain = Array.isArray(p.data.domain) ? p.data.domain[0] : p.data.domain;
    const cleanId = p.id.replace(/\.[^/.]+$/, "");
    const linkSlug = cleanId.includes('/') ? cleanId : (rawDomain ? `${slugify(rawDomain)}/${cleanId}` : cleanId);
    return { ...p, href: withBase(`/lab/${linkSlug}/`), type: 'Project' };
});

const posts = [...writingPosts, ...labPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title={`${tagLabel} · Tags · ${site.author.name}`} description={`Entries tagged with ${tagLabel}`}>
    <section class="content-shell py-12 space-y-10">
        <header class="space-y-2">
            <p class="text-sm uppercase tracking-[0.35em] text-muted">Tag</p>
            <h1 class="text-4xl font-semibold text-ink">{tagLabel}</h1>
            <p class="text-muted text-lg">Narratives and projects tagged with "{tagLabel}".</p>
        </header>

        {posts.length === 0 ? (
            <p class="text-muted">No entries found with this tag.</p>
        ) : (
            <div class="space-y-6">
                {posts.map((post) => (
                    <a
                        class="group block w-full overflow-hidden rounded-[28px] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6 transition duration-200 hover:-translate-y-[2px] hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)]"
                        href={post.href}
                    >
                        <div class="flex flex-col">
                            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-muted mb-2">
                                {post.type}
                            </p>

                            <h3 class="text-2xl font-bold text-ink group-hover:text-ink">{post.data.title}</h3>
                            <p class="mt-3 text-base text-muted line-clamp-2 leading-relaxed">{post.data.description}</p>

                            <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-[color:var(--color-border)] pt-4">
                                {post.data.tags && post.data.tags.length > 0 && (
                                    <div class="flex flex-wrap gap-2">
                                        {post.data.tags.slice(0, 3).map((tag) => (
                                            <span class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 text-xs text-muted">
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                )}

                                <time class="text-xs uppercase tracking-[0.4em] text-muted" datetime={post.data.pubDate.toISOString()}>
                                    {post.data.pubDate.toLocaleDateString('en-US', {
                                        day: 'numeric',
                                        month: 'short',
                                        year: 'numeric',
                                    })}
                                </time>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        )}
    </section>
</PageLayout>